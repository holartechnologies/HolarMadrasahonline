generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  passwordHash  String
  fullName      String
  email         String?
  phone         String?
  role          Role      @relation(fields: [roleId], references: [id])
  roleId        String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activityLogs  ActivityLog[]
  settings      SystemSettings[]
  attendanceRecords Attendance[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model Student {
  id              String         @id @default(cuid())
  admissionNumber String         @unique
  firstName       String
  lastName        String
  otherName       String?
  gender          String
  dateOfBirth     DateTime
  passportPhoto   String?
  parentName      String
  parentPhone     String
  parentEmail     String?
  address         String
  dateAdmitted    DateTime        @default(now())
  classId         String?
  status          String          @default("Active")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  class           Class?          @relation(fields: [classId], references: [id], onDelete: SetNull)
  attendances     Attendance[]
  examResults     ExamResult[]
  hifzRecords     HifzRecord[]
  assessments     CharacterAssessment[]
  payments        Payment[]
}

model Teacher {
  id              String         @id @default(cuid())
  staffId         String         @unique
  fullName        String
  phoneNumber     String
  email           String?
  qualification   String?
  dateEmployed    DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  classes         Class[]
  subjects        SubjectTeacher[]
}

model Class {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String          @unique
  teacherId       String?
  status          String          @default("Active")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  teacher         Teacher?        @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  students        Student[]
  subjects        SubjectClass[]
  attendances     Attendance[]
  examResults     ExamResult[]
  hifzRecords     HifzRecord[]
}

model Subject {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String          @unique
  description     String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  classes         SubjectClass[]
  teachers        SubjectTeacher[]
  examResults     ExamResult[]
}

model SubjectClass {
  id              String   @id @default(cuid())
  subjectId       String
  classId         String
  createdAt       DateTime @default(now())

  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([subjectId, classId])
}

model SubjectTeacher {
  id              String   @id @default(cuid())
  subjectId       String
  teacherId       String
  createdAt       DateTime @default(now())

  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([subjectId, teacherId])
}

model Attendance {
  id              String   @id @default(cuid())
  studentId       String
  classId         String
  date            DateTime
  status          String   @default("Present")
  remarks         String?
  recordedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  recordedBy      User?    @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([studentId, classId, date])
}

model Exam {
  id              String         @id @default(cuid())
  title           String
  term            String
  academicYear    String
  startDate       DateTime
  endDate         DateTime
  isPublished     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  results         ExamResult[]
}

model ExamResult {
  id              String   @id @default(cuid())
  examId          String
  studentId       String
  classId         String
  subjectId       String
  test1           Float?   @default(0)
  test2           Float?   @default(0)
  assignment      Float?   @default(0)
  examination     Float?   @default(0)
  total           Float?   @default(0)
  grade           String?
  position        Int?
  remarks         String?
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject         Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subjectId])
}

model HifzRecord {
  id                  String   @id @default(cuid())
  studentId           String
  classId             String
  currentJuz          Int      @default(1)
  currentSurah        Int      @default(1)
  sabak               String?
  sabqi               String?
  manzil              String?
  memorizationPercent Float?   @default(0)
  teacherRemarks      String?
  dateUpdated         DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class               Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId])
}

model CharacterAssessment {
  id              String   @id @default(cuid())
  studentId       String
  discipline      String   @default("Good")
  punctuality     String   @default("Good")
  respect         String   @default("Good")
  akhlaq          String   @default("Good")
  leadership      String   @default("Good")
  cleanliness     String   @default("Good")
  teacherRemarks  String?
  assessedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId])
}

model Fee {
  id              String    @id @default(cuid())
  name            String    @unique
  amount          Float
  description     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payments        Payment[]
}

model Payment {
  id              String   @id @default(cuid())
  studentId       String
  feeId           String
  amount          Float
  amountPaid      Float
  balance         Float    @default(0)
  receiptNumber   String   @unique
  paymentMethod   String   @default("Cash")
  paymentDate     DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fee             Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String
  action          String
  entityType      String?
  entityId        String?
  description     String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy       User?    @relation(fields: [updatedById], references: [id])
}

model AcademicYear {
  id              String   @id @default(cuid())
  gregorianStart  Int
  gregorianEnd    Int
  hijriStart      Int
  hijriEnd        Int
  isCurrent       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
